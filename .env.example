# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=walmart_fraud
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Data Source Configuration
# Options: "csv" (default) or "database"
# Use "csv" for deployment without exposed database port
# Use "database" when PostgreSQL is accessible
DATA_SOURCE=csv

# Application Configuration
APP_ENV=development
DEBUG=False

# MLflow Configuration
MLFLOW_TRACKING_URI=./mlflow
MLFLOW_EXPERIMENT_NAME=walmart_fraud_detection

# Paths
DATA_PATH=./data
OUTPUT_PATH=./outputs
